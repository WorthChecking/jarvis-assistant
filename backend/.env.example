# ============================================
# JARVIS Assistant 后端环境变量模板
# ============================================
# 复制本文件为 .env 并填入真实值：cp .env.example .env
# ⚠️ 切勿提交真实的 .env 文件

# === LLM 配置（DeepSeek）===
JARVIS_LLM_API_KEY=sk-your-deepseek-api-key-here
JARVIS_LLM_API_BASE=https://api.deepseek.com
JARVIS_LLM_MODEL=deepseek-chat

# === GPT-SoVITS TTS 服务 ===
# 默认本地 9880 端口，参考 https://github.com/RVC-Boss/GPT-SoVITS
JARVIS_TTS_API_BASE=http://127.0.0.1:9880

# === WebSocket 服务 ===
JARVIS_WS_HOST=0.0.0.0
JARVIS_WS_PORT=8765

# === 显存限制（RTX 3060 6GB 适配）===
JARVIS_STT_VRAM_LIMIT_MB=3072
JARVIS_TTS_VRAM_LIMIT_MB=2048
